generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String        @id @default(cuid())
  name      String?
  email     String        @unique
  password  String
  role      String        @default("USER")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]
  orders    Order[]
  reviews   Review[]
}

model ChatMessage {
  id        String   @id @default(cuid())
  chatId    String
  userId    String
  message   String
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([chatId, createdAt])
}

model TeamMember {
  id        String   @id @default(cuid())
  name      String
  role      String
  bio       String
  avatar    String   @default("?")
  imageUrl  String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id          String    @id
  name        String
  description String
  icon        String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]
}

model Product {
  id            String      @id @default(cuid())
  name          String
  brand         String
  categoryId    String
  price         Float
  originalPrice Float?
  discountPercent Float     @default(0)
  description   String
  dosage        String?
  rating        Float       @default(0)
  reviews       Int         @default(0)
  stock         Int         @default(0)
  badge         String?
  emoji         String      @default("💊")
  imageUrl      String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  costPrice     Float       @default(0)
  orderItems    OrderItem[]
  category      Category    @relation(fields: [categoryId], references: [id])
  reviewItems   Review[]
}

model Order {
  id        String      @id @default(cuid())
  userId    String?
  status    String      @default("pending")
  total     Float
  shipping  Float       @default(0)
  firstName String?
  lastName  String?
  email     String
  phone     String?
  address   String?
  city      String?
  state     String?
  zip       String?
  country   String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  user      User?       @relation(fields: [userId], references: [id])
  items     OrderItem[]
}

model Review {
  id        String   @id @default(cuid())
  rating    Int
  comment   String
  userId    String
  productId String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, productId])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Float
  costPrice Float   @default(0)
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])
}

model Consultation {
  id         String   @id @default(cuid())
  type       String
  duration   Int
  date       String
  time       String
  name       String
  email      String
  phone      String
  notes      String?
  status     String   @default("pending")
  adminNotes String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Prescription {
  id                   String   @id @default(cuid())
  type                 String
  name                 String
  email                String
  phone                String
  fileUrl              String?
  notes                String?
  currentPharmacy      String?
  currentPharmacyPhone String?
  rxNumber             String?
  medications          String?
  dob                  String?
  pickup               String?
  status               String   @default("pending")
  adminNotes           String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}
