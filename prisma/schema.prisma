generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String        @id @default(cuid())
  name      String?
  email     String        @unique
  password  String
  role      String        @default("USER") // USER | ADMIN
  orders    Order[]
  reviews   Review[]
  messages  ChatMessage[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model ChatMessage {
  id        String   @id @default(cuid())
  chatId    String   // groups messages per conversation
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  message   String
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([chatId, createdAt])
}

model TeamMember {
  id        String   @id @default(cuid())
  name      String
  role      String
  bio       String
  avatar    String   @default("?")
  imageUrl  String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id          String    @id // slug-style: "wellness", "cold-flu", etc.
  name        String
  description String
  icon        String
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id            String      @id @default(cuid())
  name          String
  brand         String
  categoryId    String
  category      Category    @relation(fields: [categoryId], references: [id])
  price         Float
  originalPrice Float?
  description   String
  dosage        String?
  rating        Float       @default(0)
  reviews       Int         @default(0)
  stock         Int         @default(0)
  badge         String? // "bestseller" | "new" | "sale"
  emoji         String      @default("💊")
  imageUrl      String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  orderItems    OrderItem[]
  reviewItems   Review[]
}

model Order {
  id        String      @id @default(cuid())
  userId    String?
  user      User?       @relation(fields: [userId], references: [id])
  status    String      @default("pending") // pending | processing | shipped | delivered
  total     Float
  shipping  Float       @default(0)
  firstName String?
  lastName  String?
  email     String
  phone     String?
  address   String?
  city      String?
  state     String?
  zip       String?
  country   String?
  items     OrderItem[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model Review {
  id        String   @id @default(cuid())
  rating    Int      // 1-5
  comment   String
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float // snapshot of price at time of order
}
