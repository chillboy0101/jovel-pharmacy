generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String        @id @default(cuid())
  name      String?
  email     String        @unique
  password  String
  role      String        @default("USER") // USER, SUPPORT, PHARMACIST, ADMIN, SUPER_ADMIN
  resetToken String?      @unique
  resetTokenExpiry DateTime?
  lastActiveAt DateTime?  // Track staff presence
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]
  assignedChats ChatMessage[] @relation("AssignedTo")
  orders    Order[]
  reviews   Review[]
  teamProfile TeamMember?
}

model ChatMessage {
  id        String   @id @default(cuid())
  chatId    String   // The unique ID for the conversation (usually the customer's userId)
  userId    String   // The sender's ID
  message   String
  isAdmin   Boolean  @default(false)
  isRead    Boolean  @default(false)
  assignedToId String? // Staff ID assigned to this client's chat
  assignedTo   User?   @relation("AssignedTo", fields: [assignedToId], references: [id])
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([chatId, createdAt])
}

model TeamMember {
  id        String   @id @default(cuid())
  name      String
  email     String?  // The email of the team member (to link to User account)
  role      String   // Job title (e.g. "Senior Pharmacist")
  bio       String
  avatar    String   @default("?")
  imageUrl  String?
  order     Int      @default(0)
  systemRole String  @default("USER") // SUPPORT, PHARMACIST, ADMIN, SUPER_ADMIN
  userId    String?  @unique // Link to the User account (legacy or specific mapping)
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id          String    @id
  name        String
  description String
  icon        String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]
}

model Product {
  id            String      @id @default(cuid())
  name          String
  brand         String
  categoryId    String
  price         Float
  originalPrice Float?
  discountPercent Float     @default(0)
  description   String
  dosage        String?
  rating        Float       @default(0)
  reviews       Int         @default(0)
  stock         Int         @default(0)
  badge         String?
  emoji         String      @default("💊")
  imageUrl      String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  costPrice     Float       @default(0)
  expiryDate    DateTime?
  orderItems    OrderItem[]
  category      Category    @relation(fields: [categoryId], references: [id])
  reviewItems   Review[]
}

model Order {
  id        String      @id @default(cuid())
  userId    String?
  status    String      @default("pending")
  total     Float
  shipping  Float       @default(0)
  prescriptionId String?
  firstName String?
  lastName  String?
  email     String
  phone     String?
  address   String?
  city      String?
  state     String?
  zip       String?
  country   String?
  paymentStatus String      @default("unpaid")
  paymentReference String?  @unique
  paymentTransactionId String?
  shippedAt DateTime?
  deliveredAt DateTime?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  user      User?       @relation(fields: [userId], references: [id])
  items     OrderItem[]
}

model Review {
  id        String   @id @default(cuid())
  rating    Int
  comment   String
  userId    String
  productId String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, productId])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Float
  costPrice Float   @default(0)
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])
}

model Consultation {
  id         String   @id @default(cuid())
  type       String
  duration   Int
  date       String
  time       String
  name       String
  email      String
  phone      String
  notes      String?
  status     String   @default("pending")
  adminNotes String?
  videoRoomId     String?  @unique
  clientJoinToken String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ConsultationVideoSignal {
  id        String   @id @default(cuid())
  roomId    String
  sender    String
  kind      String
  payload   Json
  createdAt DateTime @default(now())

  @@index([roomId, createdAt])
}

model Prescription {
  id                   String   @id @default(cuid())
  type                 String
  name                 String
  email                String
  phone                String
  fileUrl              String?
  notes                String?
  currentPharmacy      String?
  currentPharmacyPhone String?
  rxNumber             String?
  medications          String?
  dob                  String?
  pickup               String?
  status               String   @default("pending")
  adminNotes           String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model ContactMessage {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  email     String
  phone     String?
  topic     String?
  message   String
  status    String   @default("pending")
  repliedAt DateTime?
  adminNotes String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
